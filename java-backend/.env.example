# Environment Configuration for Docker Compose & Render Deployment
# Copy this file to .env and customize values as needed

# ============================================
# DEPLOYMENT OPTIONS
# ============================================
# Option 1: Docker Compose (Local Development)
#   All services run in separate containers
#   Services communicate via service names (e.g., mysql, eureka)
#
# Option 2: Render (Single Container Deployment)
#   All services run in one container on different ports
#   Gateway accessible on assigned PORT
#   Services communicate via localhost

# ============================================
# DATABASE CONFIGURATION
# ============================================
# For Local Docker: Use 'mysql' as hostname
# For Render: Use your Render PostgreSQL/MySQL host
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/project
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root123

# ============================================
# EUREKA SERVICE DISCOVERY
# ============================================
# For Local Docker: http://eureka:8761/eureka
# For Render (Single Container): http://localhost:8761/eureka
# The property file defaults to localhost, override for docker-compose
EUREKA_URL=http://localhost:8761/eureka

# ============================================
# AWS S3 CONFIGURATION (Post Service)
# ============================================
CLOUD_AWS_CREDENTIALS_ACCESSKEY=your_aws_access_key
CLOUD_AWS_CREDENTIALS_SECRETKEY=your_aws_secret_key
CLOUD_AWS_REGION_STATIC=eu-north-1
CLOUD_AWS_S3_BUCKET=bookprojectbucket1

# ============================================
# EMAIL CONFIGURATION (User Service - Mailtrap)
# ============================================
SPRING_MAIL_HOST=sandbox.smtp.mailtrap.io
SPRING_MAIL_PORT=25
SPRING_MAIL_USERNAME=your_mailtrap_username
SPRING_MAIL_PASSWORD=your_mailtrap_password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS=true

# ============================================
# APPLICATION CONFIGURATION
# ============================================
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_HIBERNATE_DDL_AUTO=update
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_HIBERNATE_SQL=DEBUG

# ============================================
# RENDER DEPLOYMENT NOTES
# ============================================
# 1. Set environment variables in Render dashboard
# 2. Ensure SPRING_DATASOURCE_URL points to accessible database
# 3. All services run on localhost internally
# 4. Gateway exposed on Render's assigned PORT
# 5. Eureka accessible on localhost:8761 internally


